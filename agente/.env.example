RABBITMQ_URL=amqp://user:password@rabbitmq-host/
RABBITMQ_AGENT_QUEUE=text_correction_jobs

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=fabrica_video_db

# Provider padrão: chatgpt ou gemini (pode ser sobrescrito por job)
DEFAULT_PROVIDER=chatgpt

# Headless false para funcionar com Xvfb + noVNC
HEADLESS=false

# Diretório para dados persistentes do Chromium (sessão/login)
CHROME_DATA_DIR=/app/chrome_data
